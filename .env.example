# .env.example — copy to .env and fill in real values
# NEVER commit .env (blocked in .gitignore)

# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database (filled after docker-compose with Postgres is up)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/llm_gateway

# Redis (filled after docker-compose with Redis is up)
REDIS_URL=redis://localhost:6379

# Auth
# Generate with: openssl rand -base64 32
GATEWAY_HMAC_PEPPER=change-me-min-32-chars-recommended

# DB statement_timeout (ms) applied at the connection level — bounds every query
# on the pool, not just auth lookups. Default 2000ms. Other query types needing
# longer bounds should use a separate pool or per-query SET LOCAL.
GATEWAY_DB_STATEMENT_TIMEOUT_MS=2000

# OpenAI (needed for proxy — Phase 1 S3)
OPENAI_API_KEY=sk-...
# Optional: override the OpenAI base URL (must be https:// outside NODE_ENV=test)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (needed for Phase 2 fallback provider)
# ANTHROPIC_API_KEY=sk-ant-...

{
  "name": "llm-gateway",
  "version": "0.0.1",
  "description": "Multi-tenant LLM API gateway with rate limiting, retry, idempotency, and semantic caching",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.app.json",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.tools.json && tsc -p tsconfig.test.json --noEmit",
    "dev": "NODE_ENV=development tsx watch src/server.ts",
    "start": "node dist/server.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint src tests",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "Pedro Ives Silva Santos <contact.pedroives@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.1.1 <12"
  },
  "packageManager": "pnpm@11.1.1",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.19",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.4",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "postgres": "^3.4.9"
  }
}
